# ═══════════════════════════════════════════════════════════════════
# PROJECT OLYMPUS — The Oracle | Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp .env olarak kaydedin. ASLA .env'i commit etmeyin.
# ═══════════════════════════════════════════════════════════════════

# ── Telegram ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_IDS=123456789

# ── Redis (önbellek & state) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM (FAZ 2+) ──────────────────────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Borsa / Veri API ──────────────────────────────────────────────
CCXT_EXCHANGE=binance
CCXT_API_KEY=
CCXT_API_SECRET=

# ── Uygulama ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DEFAULT_SYMBOL=BTC/USDT
MIN_RISK_REWARD_RATIO=0.85
SSL_VERIFY=true
